<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <domain-config>
        <domain includeSubdomains="true">spy-manager-secure.api</domain>
        <pin-set>
            <!-- Primary SHA-256 certificate pin -->
            <pin digest="SHA-256">YOUR_PRIMARY_SHA256_PIN_BASE64</pin>
            <!-- Backup pin for certificate rotation -->
            <pin digest="SHA-256">YOUR_BACKUP_SHA256_PIN_BASE64</pin>
        </pin-set>
        <!-- Enforce HTTPS only -->
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
    <!-- Block cleartext traffic -->
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
